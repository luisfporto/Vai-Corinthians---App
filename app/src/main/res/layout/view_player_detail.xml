<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/view_player_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/corinthians_black"
    android:clickable="true"
    android:elevation="10dp"
    android:focusable="true"
    android:visibility="gone">

    <Button
        android:id="@+id/btn_back_squad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="← Voltar"
        android:textColor="@color/corinthians_black"
        android:backgroundTint="@color/corinthians_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/detail_player_photo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back_squad" />

    <TextView
        android:id="@+id/detail_player_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Name"
        android:textAlignment="center"
        android:textColor="@color/corinthians_white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_player_photo" />

    <TextView
        android:id="@+id/detail_player_position"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Position"
        android:textAlignment="center"
        android:textColor="#AAAAAA"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_player_name" />

    <!-- Details Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/corinthians_gray"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/detail_player_position"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/detail_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Idade: 0"
                android:textColor="@color/corinthians_white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/detail_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Altura: 1.00m"
                android:textColor="@color/corinthians_white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/detail_nationality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nacionalidade: Brasil"
                android:textColor="@color/corinthians_white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/detail_goals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gols nesta temporada: 0"
                android:textColor="@color/corinthians_white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/detail_last_club"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Último Clube: N/A"
                android:textColor="@color/corinthians_white"
                android:textSize="18sp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
